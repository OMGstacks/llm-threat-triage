  {
    "schema_version": 1,
    "fact_id": "D1.12-due-care-vs-diligence",
    "scope": "D1",
    "claim_type": "comparison",
    "status": "active",
    "claim": "Due care is doing the right thing — implementing reasonable safeguards. Due diligence is verifying the right thing was done and remains effective through ongoing monitoring. Due care is action; due diligence is verification.",
