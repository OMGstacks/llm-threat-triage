    "fact_id": "D1.11-cia-triad",
    "scope": "D1",
    "claim_type": "concept",
    "status": "active",
    "claim": "The CIA triad — Confidentiality, Integrity, and Availability — is the foundational model of information security. Every security control and policy is designed to protect one or more of these three properties.",
