{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/cognition-hooks/datetime-sync" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/cognition-hooks/preferred-tool-reminder" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/cognition-hooks/friction-diary-signal" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/cognition-hooks/workspace-state-sync" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Read|Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/cognition-hooks/preferred-tool-gate" }
        ]
      }
    ]
  }
}
