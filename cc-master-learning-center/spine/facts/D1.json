    "scope": "D1",
    "claim_type": "comparison",
    "status": "active",
    "claim": "Authentication answers 'Who are you?' by verifying identity; authorization answers 'What are you allowed to do?' by granting or denying permissions. Authentication must succeed before authorization is applied.",
