    "schema_version": 1,
    "fact_id": "D3.31-layered-physical",
    "scope": "D3",
    "claim_type": "concept",
    "status": "active",
    "claim": "Physical security uses concentric layers: perimeter (fencing, bollards) → exterior building (locks, guards) → interior zones (badges, mantrap) → assets (equipment locks, safes). Each layer forces an attacker to defeat another control, applying the defense-in-depth principle.",
    "source": "cc-master-learning-center/reference/cc-exam-blueprint.md#physical-access-controls",
    "source_id": "isc2.cc-outline.2025-10",
    "source_tier": 0,
