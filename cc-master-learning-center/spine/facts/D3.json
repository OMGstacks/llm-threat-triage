    "fact_id": "D3.32-rbac",
    "scope": "D3",
    "claim_type": "definition",
    "status": "active",
    "claim": "RBAC (Role-Based Access Control) is an access model in which permissions are tied to roles and users are assigned to roles. Simplifies administration because permission changes apply to all users in a role at once.",
