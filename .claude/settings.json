{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(secrets/**)",
      "Read(**/secrets/**)",
      "Read(config/credentials.json)",
      "Read(**/credentials.json)",
      "Read(**/*.key)",
      "Read(**/*.pem)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "C:/Users/izuuh/projects/llm-threat-triage/.claude/cognition-hooks/datetime-sync" },
          { "type": "command", "command": "C:/Users/izuuh/projects/llm-threat-triage/.claude/cognition-hooks/preferred-tool-reminder" },
          { "type": "command", "command": "C:/Users/izuuh/projects/llm-threat-triage/.claude/cognition-hooks/friction-diary-signal" },
          { "type": "command", "command": "C:/Users/izuuh/projects/llm-threat-triage/.claude/cognition-hooks/workspace-state-sync" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Read|Bash",
        "hooks": [
          { "type": "command", "command": "C:/Users/izuuh/projects/llm-threat-triage/.claude/cognition-hooks/preferred-tool-gate" }
        ]
      }
    ]
  }
}
