    "fact_id": "D1.12-risk-trap",
    "scope": "D1",
    "claim_type": "exam_trap",
    "status": "active",
    "claim": "Risk is NOT the same as a threat. Risk requires both a threat likelihood AND an impact. Candidates often use 'threat' and 'risk' as synonyms — they are not. A threat with zero impact or zero likelihood produces zero risk.",
    "source": "cc-master-learning-center/reference/cc-exam-blueprint.md#risk-management-fundamentals",
    "source_id": "isc2.cc-outline.2025-10",
    "source_tier": 0,
    "source_fingerprint": "sha256:b2d9e5001371ce4fcdc0f5836d53d10168b29ea25a145587121e1f5fb1a3969a",
    "support": "The combination of the likelihood of a threat event and its impact",
