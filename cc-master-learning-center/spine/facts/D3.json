    "fact_id": "D3.31-mantrap-vs-cctv",
    "scope": "D3",
    "claim_type": "comparison",
    "status": "active",
    "claim": "A mantrap is a preventive control that stops tailgating by physically restricting passage; CCTV is a detective control that records what happened. The mantrap blocks the attack; the camera documents it if the attack succeeds.",
    "source": "cc-master-learning-center/reference/cc-exam-blueprint.md#physical-access-controls",
