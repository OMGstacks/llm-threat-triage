    "fact_id": "D3.32-dac",
    "scope": "D3",
    "claim_type": "definition",
    "status": "active",
    "claim": "DAC (Discretionary Access Control) is an access model in which the resource owner controls who may access the resource. Owners can grant or revoke permissions at their discretion. Most consumer operating systems use DAC.",
    "source": "cc-master-learning-center/reference/cc-exam-blueprint.md#logical-access-controls",
