  {
    "schema_version": 1,
    "fact_id": "D1.12-threat-vs-vuln",
    "scope": "D1",
    "claim_type": "comparison",
    "status": "active",
    "claim": "A threat is an external circumstance or actor that may cause harm; a vulnerability is an internal weakness that a threat can exploit. Neither alone constitutes risk — both must exist together.",
    "source": "cc-master-learning-center/reference/cc-exam-blueprint.md#risk-management-fundamentals",
    "source_id": "isc2.cc-outline.2025-10",
    "source_tier": 0,
