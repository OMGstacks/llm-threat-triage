    "fact_id": "D1.11-integrity",
    "scope": "D1",
    "claim_type": "definition",
    "status": "active",
    "claim": "Integrity is the security property of ensuring information is accurate, complete, and unaltered. Hashing, digital signatures, and checksums are common integrity controls.",
