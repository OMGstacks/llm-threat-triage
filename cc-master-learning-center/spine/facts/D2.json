    "fact_id": "D2.21-rpo",
    "scope": "D2",
    "claim_type": "definition",
    "status": "active",
    "claim": "Recovery Point Objective (RPO) is the maximum acceptable data loss measured in time. If RPO is 4 hours, the organization can tolerate losing up to 4 hours of transactions; backups must run at least every 4 hours.",
    "source": "cc-master-learning-center/reference/cc-exam-blueprint.md#business-continuity-and-disaster-recovery",
